ANTHROPIC_API_KEY=
TG_BOT_WEBHOOK_URL=
TG_BOT_WEBHOOK_SECRET=

# Telegram direct delivery (see api/order.ts, api/agent-deploy.ts)
TG_BOT_TOKEN=
TG_CHAT_ID=
TG_TOPIC_ORDER=
TG_TOPIC_OPERATOR=
TG_TOPIC_LEARNER=
TG_TOPIC_INVESTOR=
TG_TOPIC_DEPLOY=

# Hosted-agent infra (see infra/README.md)
AGENT_SECRETS_KEY=
AGENT_K8S_CONTEXT=

# Text-to-speech (ElevenLabs proxy in api/tts.ts)
# When unset, the speaker button on chat replies stays hidden.
ELEVENLABS_API_KEY=

# golden-connect-api base URL. Dev default is http://localhost:4000.
# In production set to https://api.golden-connect.ai-winlab.com or similar.
VITE_API_URL=http://localhost:4000

# Shared secret for POSTing leads from /api/chat to the golden-connect-api
# /internal/leads endpoint. Must match INTERNAL_API_SECRET in
# golden-connect-api/.env. Without it, chat <<<LEAD_SUBMIT>>> markers are
# parsed but the lead is NOT submitted (warning logged).
INTERNAL_API_SECRET=

# Base URL of golden-connect-api used by /api/chat when submitting leads
# from <<<LEAD_SUBMIT>>> markers. Falls back to VITE_API_URL, then
# http://localhost:4000 in dev.
GOLDEN_CONNECT_API_URL=

# WalletConnect Cloud projectId. Required by RainbowKit. Get one at
# https://cloud.walletconnect.com — without it mobile wallet deeplinks
# stop working. A placeholder is substituted at runtime so dev builds
# don't crash.
VITE_WC_PROJECT_ID=

# Which BNB chain to target. `mainnet` (default) uses chainId 56;
# `testnet` switches to BSC Testnet (chainId 97) — useful for QA.
VITE_BSC_CHAIN=mainnet

# Golden Connect Academy landing — used by the "Academy" link in NavBar +
# Footer. Falls back to the prod domain when unset.
VITE_ACADEMY_URL=https://golden-connect-academy.ai-winlab.com
