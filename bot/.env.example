BOT_TOKEN=123456:REPLACE_ME
ADMIN_TG_ID=1361064246
ADMIN_TG_IDS=1361064246,424077439,248745860
# trendex-api — all persistence (users, leads, reminders, ai turns,
# broadcasts) is delegated over HTTP. INTERNAL_API_SECRET must match the
# value set in the api service's own env.
INTERNAL_API_URL=http://localhost:4000
INTERNAL_API_SECRET=same-as-trendex-api
BOT_USERNAME=AgentflowWaitlistBot
WEBSITE_URL=https://trendex.website
FOUNDER_USERNAME=avsee4
EMOJI_PACK_NAME=AITrendeX
# Landing → bot webhook. Shared secret the landing sends as x-trendex-secret.
# Leave empty to accept unauthenticated POSTs (not recommended for prod).
LANDING_WEBHOOK_SECRET=
# Forum supergroup that hosts the three lead topics. Create the group, turn on
# Topics, add the bot as admin with "Manage Topics", then run /where in each
# topic to get the IDs below.
LANDING_CHAT_ID=
LANDING_TOPIC_ORDER=
LANDING_TOPIC_OPERATOR=
LANDING_TOPIC_LEARNER=
# Mini App — lands users inside a Telegram WebView with initData auth.
MINI_APP_URL=https://trendex.website/account
# Cabinet URL shown in menu + start keyboard (WebApp)
WEBAPP_URL=https://trendex.biz/cabinet
# trendex-api origin for login-token verification. Defaults to INTERNAL_API_URL.
API_URL=http://localhost:4000
# Onboarding video — shown as the one-tap CTA after /start. YouTube / Vimeo
# / MP4 all work. If empty, the bot falls back to the old long welcome.
PRESENTATION_VIDEO_URL=
# TrendeX Academy — used by /academy to deep-link into the academy
# landing with the user's ref_code baked in for attribution. Defaults to
# the prod domain when unset.
ACADEMY_URL=https://trendex-academy.ai-winlab.com
NODE_ENV=development
LOG_LEVEL=info
