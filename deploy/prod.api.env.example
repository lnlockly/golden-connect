# Template for deploy/prod.api.env (gitignored).
# Produces the `golden-connect-api-env` k8s secret via bootstrap.sh.

# Postgres (MVP reuses the shared Neon used by agentflow + trandx-dev;
# migrate to a dedicated branch before public launch).
DATABASE_URL=postgres://USER:PASS@HOST/DB?sslmode=require

# Auth / JWT. Generate: `openssl rand -hex 48`
AUTH_JWT_SECRET=
AUTH_COOKIE_DOMAIN=.golden-connect.to

# Shared secret between bot/landing and api /internal/* routes.
# Generate: `openssl rand -hex 32`
INTERNAL_API_SECRET=

# Referral / admin wiring
ADMIN_REF_CODE=admin
ADMIN_WALLETS=0x8C6AEE0a63b4F5011160BA0d455f7Ad57c1D426B

# Public base URL (used for webhook callbacks, receipts, etc.)
APP_PUBLIC_URL=https://api.golden-connect.to

# Telegram (Mini App initData HMAC — must match bot's BOT_TOKEN)
TELEGRAM_BOT_TOKEN=8926574454:AAGqFfourxakY5dmaJm1Wiaxu5zYQ4HCKPE

# Same Telegram bot token — used by services/admin-notifier.ts to DM
# admins directly from the api pod on paid entries.
BOT_TOKEN=8926574454:AAGqFfourxakY5dmaJm1Wiaxu5zYQ4HCKPE
# Comma-separated tg_ids that receive payment-landed DMs. If blank,
# admin-notifier.ts falls back to the three founder ids baked in the code.
ADMIN_TG_IDS=1361064246,424077439,248745860

# BSC intake
BSC_CHAIN_ID=56
BSC_RECEIVE_ADDRESS=0x8C6AEE0a63b4F5011160BA0d455f7Ad57c1D426B
USDT_BEP20_CONTRACT=0x55d398326f99059fF775485246999027B3197955
BSCSCAN_API_KEY=

# CryptoBot (Telegram Crypto Pay). Blank disables the route.
CRYPTOBOT_TOKEN=

# Platega.io card payments. Blank disables the route.
PLATEGA_MERCHANT_ID=
PLATEGA_API_SECRET=
PLATEGA_WEBHOOK_SECRET=
PLATEGA_BASE_URL=https://platega.io

# Landing → api webhook (lead forwarding)
LEADS_WEBHOOK_SECRET=

PORT=4001
NODE_ENV=production
LOG_LEVEL=info
