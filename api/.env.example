DATABASE_URL=postgres://user:pass@host/db?sslmode=require
AUTH_JWT_SECRET=
AUTH_COOKIE_DOMAIN=
BSC_CHAIN_ID=56
LEADS_WEBHOOK_SECRET=
# BotFather token — required for /auth/telegram (Mini App initData HMAC)
TELEGRAM_BOT_TOKEN=
# Shared secret for /internal/* endpoints. The bot sends it as
# `x-golden-connect-secret` request header. Required.
INTERNAL_API_SECRET=
PORT=4000
# Payment intake — Platega.io (fiat card, RUB). Leave any of MERCHANT_ID /
# API_SECRET / WEBHOOK_SECRET blank to disable; POST /me/pay/platega then
# returns 503 `platega_not_configured`.
PLATEGA_MERCHANT_ID=
PLATEGA_API_SECRET=
PLATEGA_WEBHOOK_SECRET=
PLATEGA_BASE_URL=https://platega.io
# Static USD→RUB rate applied to tariff entry amounts. Swap for a CBR-rate
# feed when that integration lands.
PLATEGA_USD_RATE=95
# Public origin used for provider callback_url / return_url.
APP_PUBLIC_URL=https://api.golden-connect.to
# BEP-20 USDT intake. Receive address is the admin wallet. USDT contract
# is the BSC mainnet USDT. BSCSCAN_API_KEY is for a future watcher job.
BSC_RECEIVE_ADDRESS=0x8C6AEE0a63b4F5011160BA0d455f7Ad57c1D426B
USDT_BEP20_CONTRACT=0x55d398326f99059fF775485246999027B3197955
BSCSCAN_API_KEY=
# CryptoBot (Telegram @CryptoBot) Crypto Pay API token. Obtain from
# @CryptoBot → Crypto Pay → Create App. Blank = /me/pay/cryptobot
# returns 503 and /webhooks/cryptobot is a silent no-op.
CRYPTOBOT_TOKEN=
# Bot token used by services/admin-notifier.ts to DM admins on a paid entry.
# Same token as the bot pod's BOT_TOKEN. Blank disables admin DMs.
BOT_TOKEN=
# Comma-separated tg_ids that receive admin DMs + have access to the /payments
# admin view in the bot. Falls back to founder list in admin-notifier.ts.
ADMIN_TG_IDS=1361064246,424077439,248745860
# Optional JSON override for the referral reward curve. Shape is an array
# of { "levels": [from, to], "pct": 0.10 }. See services/rewards.ts for
# the built-in default.
REFERRAL_CURVE_JSON=
