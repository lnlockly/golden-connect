{
  "name": "golden-connect-api",
  "version": "0.1.0",
  "private": true,
  "description": "Golden Connect backend — hono + Drizzle + Postgres",
  "type": "module",
  "main": "dist/server.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "migrate": "drizzle-kit migrate",
    "generate": "drizzle-kit generate",
    "push": "drizzle-kit push",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "seed:gamification": "tsx scripts/seed-gamification.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.36.4",
    "hono": "^4.6.14",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "pino": "^9.5.0",
    "postgres": "^3.4.5",
    "qrcode": "^1.5.3",
    "siwe": "^2.3.2",
    "viem": "^2.21.55",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "@types/qrcode": "^1.5.5",
    "better-sqlite3": "^12.9.0",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
